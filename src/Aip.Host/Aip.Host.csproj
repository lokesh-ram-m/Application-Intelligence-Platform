<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
  </PropertyGroup>
  <ItemGroup>
    <!-- Unlocks WebApplication/minimal APIs for `serve` mode (Serve.cs) without switching the whole
         project to the Web SDK — every other CLI mode (verify/demo/run) is unaffected. -->
