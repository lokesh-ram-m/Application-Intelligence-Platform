  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../Aip.Core/Aip.Core.csproj" />
    <ProjectReference Include="../Aip.Abstractions/Aip.Abstractions.csproj" />
    <ProjectReference Include="../Aip.Analysis/Aip.Analysis.csproj" />
    <ProjectReference Include="../Aip.Knowledge/Aip.Knowledge.csproj" />
    <ProjectReference Include="../Aip.Projections/Aip.Projections.csproj" />
    <ProjectReference Include="../Aip.Ai/Aip.Ai.csproj" />
    <ProjectReference Include="../Aip.Query/Aip.Query.csproj" />
    <ProjectReference Include="../Aip.Registries/Aip.Registries.csproj" />
    <ProjectReference Include="../Aip.Observability/Aip.Observability.csproj" />
    <ProjectReference Include="../Aip.Infrastructure/Aip.Infrastructure.csproj" />
    <ProjectReference Include="../Aip.Infrastructure.AzureBlob/Aip.Infrastructure.AzureBlob.csproj" />
    <ProjectReference Include="../Aip.Engines.Roslyn/Aip.Engines.Roslyn.csproj" />
    <ProjectReference Include="../Aip.Engines.TypeScript/Aip.Engines.TypeScript.csproj" />
    <ProjectReference Include="../Aip.Plugins.AspNetCore/Aip.Plugins.AspNetCore.csproj" />
    <ProjectReference Include="../Aip.Plugins.Angular/Aip.Plugins.Angular.csproj" />
    <ProjectReference Include="../Aip.Plugins.React/Aip.Plugins.React.csproj" />
    <ProjectReference Include="../Aip.Plugins.NextJs/Aip.Plugins.NextJs.csproj" />
    <ProjectReference Include="../Aip.Plugins.Security/Aip.Plugins.Security.csproj" />
